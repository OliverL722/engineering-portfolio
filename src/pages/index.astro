      .detail-media { min-height: 300px; border: 1px dashed rgba(var(--accent-rgb), .35); border-radius: 10px; display: grid; place-items: center; background: repeating-linear-gradient(45deg, var(--panel2), var(--panel2) 9px, var(--panel) 9px, var(--panel) 18px); color: var(--accent); text-align: center; padding: 1.4rem; font-family: "Space Mono", monospace; font-size: .85rem; }
