                <p class="project-number">Highlights</p>
                <h3>Project summary</h3>
              </div>

              <ul id="individualBullets" class="detail-bullet-list"></ul>
            </section>

            <div class="detail-media large-media">
              <span id="individualMainImage">Main image placeholder</span>
            </div>
          </div>

