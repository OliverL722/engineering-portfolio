          <article class="education-card">
            <p class="project-number">Courses</p>
            <h3>Relevant Coursework</h3>
            <p class="project-type">Mechanical · CS · Analysis</p>
            <ul>
              <li>Dynamics</li>
              <li>Thermodynamics</li>
              <li>Design for Manufacturing</li>
              <li>CAD / Mechanical Design</li>
