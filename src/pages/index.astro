---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Oliver Lesiakowski | Engineering Portfolio</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>

  <body>
    <header class="site-header">
      <h1>Oliver Lesiakowski</h1>
      <p>Mechanical Engineering · CS · UIUC</p>
    </header>

    <nav class="top-nav">
      <button class="tab-button active" data-tab="education">Education</button>
      <button class="tab-button" data-tab="projects">Projects</button>
      <button class="tab-button" data-tab="experience">Experience</button>
      <a
        class="nav-link"
        href="https://www.linkedin.com/"
        target="_blank"
        rel="noopener noreferrer"
      >
        LinkedIn
      </a>
    </nav>

    <main class="page">
      <section id="education" class="screen active">
        <p class="section-label">01. Education</p>
        <h2>Academic background.</h2>

        <div class="education-grid">
          <article class="education-card main-education">
            <p class="project-number">UIUC</p>
            <h3>University of Illinois Urbana-Champaign</h3>
            <p class="project-type">Mechanical Engineering · Expected May 2028</p>
            <p>
              Sophomore studying mechanical engineering with interests in product
              design, prototyping, manufacturing, robotics, and electromechanical systems.
            </p>
          </article>

          <article class="education-card">
            <p class="project-number">GPA</p>
            <h3>3.81 / 4.00</h3>
            <p class="project-type">Academic performance</p>
            <p>Current GPA. Update before using professionally if needed.</p>
          </article>

          <article class="education-card">
            <p class="project-number">Courses</p>
            <h3>Relevant Coursework</h3>
            <p class="project-type">Mechanical · CS · Analysis</p>
            <ul>
              <li>Dynamics</li>
              <li>Thermodynamics</li>
              <li>Design for Manufacturing</li>
              <li>CAD / Mechanical Design</li>
              <li>Data Structures in C++</li>
              <li>Linear Algebra</li>
            </ul>
          </article>

          <article class="education-card">
            <p class="project-number">Focus</p>
            <h3>Relevant Focus</h3>
            <p class="project-type">Design · Testing · Technical Work</p>
            <ul>
              <li>Product design and prototyping</li>
              <li>Mechanical testing and validation</li>
              <li>Electronics, wiring, and soldering</li>
              <li>Manufacturing and hands-on fabrication</li>
            </ul>
          </article>
        </div>
      </section>

      <section id="projects" class="screen">
        <p class="section-label">02. Projects</p>
        <h2>Selected work.</h2>

        <div class="project-grid">
          <article class="project-card">
            <p class="project-number">01</p>
            <h3>DeckStep™ Shoe Rack</h3>
            <p class="project-type">Repurposed skateboard deck with 3D-printed PETG supports.</p>

            <div class="trait-list">
              <span>Fusion 360</span>
              <span>3D Printing</span>
              <span>PETG</span>
              <span>Product Design</span>
              <span>DFA</span>
              <span>GD&T</span>
              <span>Prototyping</span>
            </div>
          </article>

          <article class="project-card">
            <p class="project-number">02</p>
            <h3>Antweight Combat Robot</h3>
            <p class="project-type">Small combat robot involving CAD, wiring, soldering, and testing.</p>

            <div class="trait-list">
              <span>Robotics</span>
              <span>CAD</span>
              <span>3D Printing</span>
              <span>Soldering</span>
              <span>Electronics</span>
              <span>Drivetrain</span>
              <span>Testing</span>
            </div>
          </article>

          <article class="project-card">
            <p class="project-number">03</p>
            <h3>Folding Numpad</h3>
            <p class="project-type">Portable hinge-based numpad concept with CAD assembly and BOM.</p>

            <div class="trait-list">
              <span>Fusion 360</span>
              <span>CAD Assembly</span>
              <span>Mechanisms</span>
              <span>BOM</span>
              <span>Design Docs</span>
              <span>Product Design</span>
            </div>
          </article>

          <article class="project-card">
            <p class="project-number">04</p>
            <h3>Electric Ride-On Mods</h3>
            <p class="project-type">Modified electric ride-on system with upgraded power electronics.</p>

            <div class="trait-list">
              <span>Batteries</span>
              <span>Motors</span>
              <span>Wiring</span>
              <span>BLDC Controller</span>
              <span>Electronics</span>
              <span>Troubleshooting</span>
            </div>
          </article>
        </div>
      </section>

      <section id="experience" class="screen">
        <p class="section-label">03. Experience</p>
        <h2>Technical experience.</h2>

        <div class="timeline">
          <article class="timeline-item reveal">
            <div class="timeline-dot"></div>

            <div class="timeline-card">
              <div class="timeline-media">
                <img src="/images/experience/MSI_Logo.png" alt="Motorola Solutions logo" />
              </div>

              <div class="timeline-content">
                <p class="timeline-date">Summer 2026</p>
                <h3>Motorola Solutions</h3>
                <p class="timeline-role">Battery Cell Engineering Intern</p>

                <ul>
                  <li class="typewrite">Supporting battery cell testing, validation, and safety-related engineering work.</li>
                  <li class="typewrite">Working in a lab environment with mechanical, electrical, and test equipment.</li>
                  <li class="typewrite">Applying hands-on engineering skills to real product reliability and safety problems.</li>
                </ul>

                <div class="trait-list">
                  <span>Battery Systems</span>
                  <span>Testing</span>
                  <span>Validation</span>
                  <span>Lab Work</span>
                  <span>Safety</span>
                </div>
              </div>
            </div>
          </article>

          <article class="timeline-item reveal">
            <div class="timeline-dot"></div>

            <div class="timeline-card">
              <div class="timeline-media">
                <img src="/images/experience/UIUC_Logo.png" alt="University of Illinois logo" />
              </div>

              <div class="timeline-content">
                <p class="timeline-date">2026</p>
                <h3>University of Illinois Urbana-Champaign</h3>
                <p class="timeline-role">Undergraduate Mechanical Engineering Research Assistant</p>

                <ul>
                  <li class="typewrite">Supporting experimental setup and technical lab development.</li>
                  <li class="typewrite">Working with mechanical fabrication, wiring, and instrumentation tasks.</li>
                  <li class="typewrite">Building practical research experience in an engineering lab environment.</li>
                </ul>

                <div class="trait-list">
                  <span>Research</span>
                  <span>Fabrication</span>
                  <span>Instrumentation</span>
                  <span>Wiring</span>
                  <span>Lab Setup</span>
                </div>
              </div>
            </div>
          </article>

          <article class="timeline-item reveal">
            <div class="timeline-dot"></div>

            <div class="timeline-card">
              <div class="timeline-media">
                <img src="/images/experience/TipTek_Logo.png" alt="TipTek logo" />
              </div>

              <div class="timeline-content">
                <p class="timeline-date">October 2025 – December 2025</p>
                <h3>TipTek</h3>
                <p class="timeline-role">Production Technician</p>

                <ul>
                  <li class="typewrite">Produced and inspected tungsten nanoprobes for chip-related applications.</li>
                  <li class="typewrite">Used microscope-based validation to check probe sharpness and quality.</li>
                  <li class="typewrite">Worked in a precision production environment requiring consistency and accuracy.</li>
                </ul>

                <div class="trait-list">
                  <span>Microscope Work</span>
                  <span>Production</span>
                  <span>Quality Control</span>
                  <span>Precision</span>
                  <span>Materials</span>
                </div>
              </div>
            </div>
          </article>

          <article class="timeline-item reveal">
            <div class="timeline-dot"></div>

            <div class="timeline-card">
              <div class="timeline-media">
                <img src="/images/experience/Truevalue_Logo.jpg" alt="True Value logo" />
              </div>

              <div class="timeline-content">
                <p class="timeline-date">July 2023 – August 2024</p>
                <h3>True Value Hardware</h3>
                <p class="timeline-role">Hardware Sales and Service Associate</p>

                <ul>
                  <li class="typewrite">Assisted customers with hardware, tools, parts, paint, keys, and repair services.</li>
                  <li class="typewrite">Completed hands-on service work including screen repair, pipe cutting, and key duplication.</li>
                  <li class="typewrite">Built practical familiarity with hardware, fasteners, materials, and customer problem solving.</li>
                </ul>

                <div class="trait-list">
                  <span>Hardware</span>
                  <span>Tools</span>
                  <span>Customer Service</span>
                  <span>Repair</span>
                  <span>Materials</span>
                </div>
              </div>
            </div>
          </article>
        </div>
      </section>
    </main>

    <script>
      const tabButtons = document.querySelectorAll(".tab-button");
      const screens = document.querySelectorAll(".screen");
      const revealItems = document.querySelectorAll(".reveal");
      const typewriteElements = document.querySelectorAll(".typewrite");

      typewriteElements.forEach((element) => {
        element.dataset.fullText = element.textContent.trim();
        element.textContent = "";
      });

      function typeText(element, speed = 3) {
        return new Promise((resolve) => {
          if (element.dataset.typed === "true") {
            resolve();
            return;
          }

          const fullText = element.dataset.fullText || "";
          let index = 0;

          element.textContent = "";
          element.dataset.typed = "true";

          const interval = setInterval(() => {
            element.textContent += fullText[index];
            index += 1;

            if (index >= fullText.length) {
              clearInterval(interval);
              resolve();
            }
          }, speed);
        });
      }

      async function typeExperienceCard(item) {
        if (item.dataset.cardTyped === "true") return;

        item.dataset.cardTyped = "true";

        const textElements = item.querySelectorAll(".typewrite");

        for (const element of textElements) {
          await typeText(element);
          await new Promise((resolve) => setTimeout(resolve, 15));
        }
      }

      function revealVisibleTimelineItems() {
        revealItems.forEach((item) => {
          if (item.getBoundingClientRect().top < window.innerHeight * 0.7) {
            item.classList.add("visible");
            typeExperienceCard(item);
          }
        });
      }

      function showTab(tabName) {
        tabButtons.forEach((button) => {
          button.classList.toggle("active", button.dataset.tab === tabName);
        });

        screens.forEach((screen) => {
          screen.classList.toggle("active", screen.id === tabName);
        });

        history.replaceState(null, "", `#${tabName}`);

        if (tabName === "experience") {
          setTimeout(revealVisibleTimelineItems, 80);
        }
      }

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => {
          showTab(button.dataset.tab);
        });
      });

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              typeExperienceCard(entry.target);
            }
          });
        },
        {
          root: null,
          rootMargin: "0px 0px -30% 0px",
          threshold: 0.4,
        }
      );

      revealItems.forEach((item) => revealObserver.observe(item));

      const startingTab = window.location.hash.replace("#", "");

      if (["education", "projects", "experience"].includes(startingTab)) {
        showTab(startingTab);
      } else {
        showTab("education");
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #000000;
    --bg-light: #0d1117;
    --nav-bg: rgba(0, 0, 0, 0.9);
    --text: #ccd6f6;
    --muted: #8892b0;
    --accent: #64ffda;
    --white: #e6f1ff;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .site-header {
    width: 100%;
    text-align: center;
    padding: 3.5rem 1rem 2rem;
    background: var(--bg);
  }

  .site-header h1 {
    margin: 0;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .site-header p {
    margin: 0.8rem 0 0;
    color: var(--accent);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.95rem;
  }

  .top-nav {
    position: sticky;
    top: 0;
    z-index: 9999;
    width: 100%;
    min-height: 82px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(100, 255, 218, 0.08);
    border-bottom: 1px solid rgba(100, 255, 218, 0.12);
  }

  .tab-button,
  .nav-link {
    color: var(--muted);
    text-decoration: none;
    padding: 0.85rem 1.15rem;
    border: 1px solid rgba(136, 146, 176, 0.35);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.02);
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
    font-size: 0.92rem;
    cursor: pointer;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .tab-button:hover,
  .nav-link:hover,
  .tab-button.active {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(100, 255, 218, 0.1);
  }

  .tab-button:hover,
  .nav-link:hover {
    transform: translateY(-2px);
  }

  .page {
    width: min(1120px, 90%);
    margin: 0 auto;
  }

  .screen {
    display: none;
    padding: 6rem 0;
    min-height: calc(100vh - 82px);
  }

  .screen.active {
    display: block;
    animation: fadeIn 0.22s ease-in-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .section-label,
  .project-type,
  .project-number,
  .timeline-date,
  .timeline-role {
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  .section-label {
    color: var(--accent);
    margin-bottom: 0.8rem;
  }

  h2 {
    color: var(--white);
    font-size: 2rem;
    margin: 0 0 2rem;
  }

  .project-grid,
  .education-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }

  .project-card,
  .education-card {
    min-height: 230px;
    padding: 1.5rem;
    border: 1px solid rgba(100, 255, 218, 0.12);
    background: var(--bg-light);
    border-radius: 10px;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .project-card:hover,
  .education-card:hover {
    transform: translateY(-4px);
    border-color: rgba(100, 255, 218, 0.45);
  }

  .main-education {
    grid-column: span 2;
  }

  .project-number {
    color: var(--accent);
    margin: 0 0 2rem;
  }

  h3 {
    color: var(--white);
    font-size: 1.35rem;
    margin: 0 0 0.7rem;
  }

  .project-type {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 1.2rem;
  }

  .education-card p:last-child {
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }

  .education-card ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
    line-height: 1.8;
  }

  .education-card li::marker,
  .timeline-content li::marker {
    color: var(--accent);
  }

  .trait-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.3rem;
  }

  .trait-list span {
    border: 1px solid rgba(100, 255, 218, 0.25);
    background: rgba(100, 255, 218, 0.06);
    color: var(--accent);
    padding: 0.5rem 0.7rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
  }

  .timeline {
    position: relative;
    margin-top: 3rem;
    padding-left: 3rem;
  }

  .timeline::before {
    content: "";
    position: absolute;
    top: 0.5rem;
    left: 0.65rem;
    width: 2px;
    height: calc(100% - 1rem);
    background: linear-gradient(
      to bottom,
      rgba(100, 255, 218, 0.85),
      rgba(100, 255, 218, 0.12)
    );
  }

  .timeline-item {
    position: relative;
    margin-bottom: 8rem;
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
  }

  .timeline-item:last-child {
    margin-bottom: 2rem;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-dot {
    position: absolute;
    left: -2.85rem;
    top: 1.7rem;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow:
      0 0 0 6px rgba(100, 255, 218, 0.08),
      0 0 26px rgba(100, 255, 218, 0.55);
  }

  .timeline-card {
    display: grid;
    grid-template-columns: 170px 1fr;
    gap: 1.5rem;
    padding: 1.5rem;
    border: 1px solid rgba(100, 255, 218, 0.12);
    background:
      linear-gradient(135deg, rgba(100, 255, 218, 0.04), transparent 35%),
      var(--bg-light);
    border-radius: 12px;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .timeline-card:hover {
    transform: translateY(-4px);
    border-color: rgba(100, 255, 218, 0.45);
  }

  .timeline-media {
    min-height: 150px;
    border: none;
    border-radius: 10px;
    display: grid;
    place-items: center;
    color: var(--accent);
    background: transparent;
    overflow: hidden;
  }

  .timeline-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.2rem;
  }

  .timeline-date {
    color: var(--accent);
    margin: 0 0 0.7rem;
    font-size: 0.92rem;
  }

  .timeline-role {
    color: var(--accent);
    margin: 0 0 1rem;
    font-size: 0.92rem;
    font-style: italic;
  }

  .timeline-content ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
    line-height: 1.8;
  }

  @media (max-width: 780px) {
    .site-header {
      padding: 2.4rem 1rem 1.4rem;
    }

    .top-nav {
      justify-content: flex-start;
      overflow-x: auto;
      gap: 0.8rem;
    }

    .tab-button,
    .nav-link {
      white-space: nowrap;
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
    }

    .screen {
      padding: 4rem 0;
    }

    .project-grid,
    .education-grid {
      grid-template-columns: 1fr;
    }

    .main-education {
      grid-column: span 1;
    }

    .timeline {
      padding-left: 2rem;
    }

    .timeline::before {
      left: 0.45rem;
    }

    .timeline-dot {
      left: -2rem;
    }

    .timeline-item {
      margin-bottom: 6rem;
    }

    .timeline-item:last-child {
      margin-bottom: 2rem;
    }

    .timeline-card {
      grid-template-columns: 1fr;
    }

    .timeline-media {
      min-height: 120px;
    }
  }
</style>