      typewriteElements.forEach((element) => {
        element.dataset.fullText = element.textContent.trim();
        element.textContent = "";
      });

      function typeText(element, speed = 3) {
        return new Promise((resolve) => {
          if (element.dataset.typed === "true") {
            resolve();
            return;
          }

          const fullText = element.dataset.fullText || "";
          let index = 0;

          element.textContent = "";
          element.dataset.typed = "true";

          const interval = setInterval(() => {
            element.textContent += fullText[index];
            index += 1;

            if (index >= fullText.length) {
              clearInterval(interval);
              resolve();
            }
          }, speed);
        });
      }

      async function typeExperienceCard(item) {
        if (item.dataset.cardTyped === "true") return;

        item.dataset.cardTyped = "true";

        const textElements = item.querySelectorAll(".typewrite");

        for (const element of textElements) {
          await typeText(element);
          await new Promise((resolve) => setTimeout(resolve, 15));
        }
      }

      function revealVisibleTimelineItems() {
        revealItems.forEach((item) => {
          if (item.getBoundingClientRect().top < window.innerHeight * 0.7) {
            item.classList.add("visible");
            typeExperienceCard(item);
          }
        });
      }

      function jumpToProjectsTop() {
        const navHeight = topNav?.offsetHeight || 82;
        const projectTop = projectsScreen.getBoundingClientRect().top + window.scrollY;
        const targetTop = Math.max(0, projectTop - navHeight - 8);

        window.scrollTo({
          top: targetTop,
          behavior: "auto"
        });
      }


      function fillTags(container, tags) {
        container.innerHTML = "";

        tags.forEach((tag) => {
          const tagElement = document.createElement("span");
          tagElement.textContent = tag;
          container.appendChild(tagElement);
        });
      }

      function fillBullets(container, bullets) {
        container.innerHTML = "";

        bullets.forEach((bullet) => {
          const item = document.createElement("li");
          item.textContent = bullet;
          container.appendChild(item);
        });
      }

      function createBulletList(items) {
        const list = document.createElement("ul");
        list.className = "detail-bullet-list";

        items.forEach((item) => {
          const listItem = document.createElement("li");
          listItem.textContent = item;
          list.appendChild(listItem);
        });

        return list;
      }

      function populateCategory(category) {
        categoryKicker.textContent = category.kicker;
        categoryTitle.textContent = category.title;
        categoryTime.textContent = category.time;
        categoryDescription.textContent = category.description;

        fillTags(categoryTags, category.tags);

        categoryProjectRows.innerHTML = "";

        category.projects.forEach((project, index) => {
          const row = document.createElement("button");
          row.className = "project-row";
          row.type = "button";
          row.dataset.projectIndex = index;

          const tagHTML = project.tags
            .slice(0, 4)
            .map((tag) => `<span>${tag}</span>`)
            .join("");

          row.innerHTML = `
            <div class="project-row-main">
              <p class="project-number">${String(index + 1).padStart(2, "0")}</p>

              <div class="project-row-text">
                <h3>${project.title}</h3>
