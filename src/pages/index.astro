      };

      typewriteElements.forEach((element) => {
        element.dataset.fullText = element.textContent.trim();
        element.textContent = "";
      });

      function typeText(element, speed = 3) {
        return new Promise((resolve) => {
          if (element.dataset.typed === "true") {
            resolve();
            return;
          }

          const fullText = element.dataset.fullText || "";
          let index = 0;

          element.textContent = "";
          element.dataset.typed = "true";

          const interval = setInterval(() => {
            element.textContent += fullText[index];
            index += 1;

            if (index >= fullText.length) {
              clearInterval(interval);
              resolve();
            }
          }, speed);
        });
      }

      async function typeExperienceCard(item) {
        if (item.dataset.cardTyped === "true") return;

        item.dataset.cardTyped = "true";

        const textElements = item.querySelectorAll(".typewrite");

        for (const element of textElements) {
          await typeText(element);
          await new Promise((resolve) => setTimeout(resolve, 15));
        }
      }

      function revealVisibleTimelineItems() {
        revealItems.forEach((item) => {
          if (item.getBoundingClientRect().top < window.innerHeight * 0.7) {
            item.classList.add("visible");
            typeExperienceCard(item);
          }
        });
      }

      function getTitleSnapshot(element) {
        if (!element) return null;

        const rect = element.getBoundingClientRect();
        const styles = window.getComputedStyle(element);

        return {
          text: element.textContent.trim(),
          left: rect.left,
          top: rect.top,
          width: rect.width,
          fontSizeNumber: parseFloat(styles.fontSize) || 16,
          fontWeight: styles.fontWeight,
          letterSpacing: styles.letterSpacing,
          lineHeight: styles.lineHeight
        };
      }

      function animateTitleSnapshot(snapshot, toElement, callback, duration = 280) {
        if (!snapshot || !toElement) {
          if (callback) callback();
          return;
        }

        const toRect = toElement.getBoundingClientRect();
        const toStyles = window.getComputedStyle(toElement);
        const targetFontSize = parseFloat(toStyles.fontSize) || snapshot.fontSizeNumber;
        const startScale = snapshot.fontSizeNumber / targetFontSize;

        const startX = snapshot.left;
        const startY = snapshot.top;
        const endX = toRect.left;
        const endY = toRect.top;

        const clone = document.createElement("div");
        clone.className = "title-flight";
        clone.textContent = snapshot.text;

        clone.style.setProperty("--flight-duration", `${duration}ms`);
        clone.style.left = `${startX}px`;
        clone.style.top = `${startY}px`;
        clone.style.width = `${Math.max(toRect.width, snapshot.width / startScale)}px`;
        clone.style.fontSize = toStyles.fontSize;
        clone.style.fontWeight = toStyles.fontWeight;
        clone.style.letterSpacing = toStyles.letterSpacing;
        clone.style.lineHeight = toStyles.lineHeight;
        clone.style.transform = `translate3d(0, 0, 0) scale(${startScale})`;

        document.body.appendChild(clone);
        toElement.classList.add("title-hidden");

        requestAnimationFrame(() => {
          clone.style.transform = `translate3d(${endX - startX}px, ${endY - startY}px, 0) scale(1)`;
        });

        setTimeout(() => {
          toElement.classList.remove("title-hidden");
          clone.classList.add("title-flight-fade");

          setTimeout(() => {
            clone.remove();

            if (callback) callback();
          }, 70);
        }, duration);
      }

      function fillTags(container, tags) {
        container.innerHTML = "";

        tags.forEach((tag) => {
          const tagElement = document.createElement("span");
          tagElement.textContent = tag;
          container.appendChild(tagElement);
        });
      }

      function fillBullets(container, bullets) {
        container.innerHTML = "";

        bullets.forEach((bullet) => {
          const item = document.createElement("li");
          item.textContent = bullet;
          container.appendChild(item);
        });
      }

      function createBulletList(items) {
        const list = document.createElement("ul");
        list.className = "detail-bullet-list";

        items.forEach((item) => {
          const listItem = document.createElement("li");
          listItem.textContent = item;
          list.appendChild(listItem);
        });

        return list;
      }

      function populateCategory(category) {
        categoryKicker.textContent = category.kicker;
        categoryTitle.textContent = category.title;
        categoryTime.textContent = category.time;
        categoryDescription.textContent = category.description;

        fillTags(categoryTags, category.tags);

        categoryProjectRows.innerHTML = "";

        category.projects.forEach((project, index) => {
          const row = document.createElement("button");
          row.className = "project-row";
          row.type = "button";
          row.dataset.projectIndex = index;

          const tagHTML = project.tags
            .slice(0, 4)
            .map((tag) => `<span>${tag}</span>`)
            .join("");

          row.innerHTML = `
            <div class="project-row-main">
              <p class="project-number">${String(index + 1).padStart(2, "0")}</p>

              <div class="project-row-text">
                <h3>${project.title}</h3>
                <p>${project.time}</p>
              </div>
            </div>

            <div class="project-row-tags">
              ${tagHTML}
            </div>

            <span class="project-row-action">View more →</span>
          `;

          row.addEventListener("click", () => {
            openIndividualProject(index, row);
          });

          categoryProjectRows.appendChild(row);
        });
      }

      function populateIndividual(project, category) {
        individualKicker.textContent = category.title;
        individualTitle.textContent = project.title;
        individualTime.textContent = project.time;
        individualDescription.textContent = project.description;
        individualMainImage.textContent = project.image;

        fillTags(individualTags, project.tags);
        fillBullets(individualBullets, project.bullets);

        individualSections.innerHTML = "";

        project.sections.forEach((section) => {
          const sectionCard = document.createElement("section");
          sectionCard.className = "detail-wide-section";

          const content = document.createElement("div");
          content.className = "detail-wide-content";

          const label = document.createElement("p");
          label.className = "project-number";
          label.textContent = section.label;

          const title = document.createElement("h3");
          title.textContent = section.title;

          content.appendChild(label);
          content.appendChild(title);
          content.appendChild(createBulletList(section.bullets));

          const media = document.createElement("div");
          media.className = "detail-media section-media";

          const mediaText = document.createElement("span");
          mediaText.textContent = section.image;
          media.appendChild(mediaText);

          sectionCard.appendChild(content);
          sectionCard.appendChild(media);

          individualSections.appendChild(sectionCard);
        });
      }

      function openCategory(categoryId, card) {
        const category = projectData[categoryId];
        if (!category) return;

        activeCategoryId = categoryId;
        activeCategoryCard = card;

        populateCategory(category);

        const sourceTitle = card.querySelector(".card-title");
        const titleSnapshot = getTitleSnapshot(sourceTitle);

        card.classList.add("launching");
        projectsOverview.classList.add("overview-exiting");

        setTimeout(() => {
          projectsOverview.hidden = true;
          projectCategoryPage.hidden = false;
          projectCategoryPage.classList.remove("closing");

          requestAnimationFrame(() => {
            projectCategoryPage.classList.add("active");

            setTimeout(() => {
              animateTitleSnapshot(titleSnapshot, categoryTitle, () => {
                card.classList.remove("launching");
              }, 280);
            }, 30);
          });

          projectCategoryPage.scrollIntoView({
            behavior: "smooth",
            block: "start"
          });
        }, 130);
      }

      function closeCategory(animate = true) {
        if (projectCategoryPage.hidden) return;

        if (!animate) {
          projectCategoryPage.hidden = true;
          projectCategoryPage.classList.remove("active", "closing");
          projectsOverview.hidden = false;
          projectsOverview.classList.remove("overview-exiting");
          return;
        }

        const titleSnapshot = getTitleSnapshot(categoryTitle);
        const targetTitle = activeCategoryCard?.querySelector(".card-title");

        projectsOverview.hidden = false;
        projectsOverview.classList.remove("overview-exiting");

        projectCategoryPage.classList.remove("active");
        projectCategoryPage.classList.add("closing");

        projectsOverview.scrollIntoView({
          behavior: "auto",
          block: "start"
        });

        requestAnimationFrame(() => {
          animateTitleSnapshot(titleSnapshot, targetTitle, null, 220);
        });

        setTimeout(() => {
          projectCategoryPage.hidden = true;
          projectCategoryPage.classList.remove("closing");
        }, 210);
      }

      function openIndividualProject(projectIndex, sourceRow) {
        const category = projectData[activeCategoryId];
        const project = category?.projects[projectIndex];

        if (!project || !category) return;

        activeProjectRow = sourceRow;

        populateIndividual(project, category);

        const sourceTitle = sourceRow.querySelector("h3");
        const titleSnapshot = getTitleSnapshot(sourceTitle);

        sourceRow.classList.add("launching");
        projectCategoryPage.classList.remove("active");
        projectCategoryPage.classList.add("overview-exiting");

        setTimeout(() => {
          projectCategoryPage.hidden = true;
          individualProjectPage.hidden = false;
          individualProjectPage.classList.remove("closing");

          requestAnimationFrame(() => {
            individualProjectPage.classList.add("active");

            setTimeout(() => {
              animateTitleSnapshot(titleSnapshot, individualTitle, () => {
                sourceRow.classList.remove("launching");
              }, 280);
            }, 30);
          });

          individualProjectPage.scrollIntoView({
            behavior: "smooth",
            block: "start"
          });
        }, 130);
      }

      function closeIndividualProject(animate = true) {
        if (individualProjectPage.hidden) return;

        if (!animate) {
          individualProjectPage.hidden = true;
          individualProjectPage.classList.remove("active", "closing");
          projectCategoryPage.hidden = false;
          projectCategoryPage.classList.add("active");
          projectCategoryPage.classList.remove("overview-exiting");
          return;
        }

        const titleSnapshot = getTitleSnapshot(individualTitle);
        const targetTitle = activeProjectRow?.querySelector("h3");

        projectCategoryPage.hidden = false;
        projectCategoryPage.classList.remove("overview-exiting", "closing", "behind-detail");
        projectCategoryPage.classList.add("active");

        individualProjectPage.classList.remove("active");
        individualProjectPage.classList.add("closing");

        projectCategoryPage.scrollIntoView({
          behavior: "auto",
          block: "start"
        });

        requestAnimationFrame(() => {
          animateTitleSnapshot(titleSnapshot, targetTitle, null, 220);
        });

        setTimeout(() => {
          individualProjectPage.hidden = true;
          individualProjectPage.classList.remove("closing");
        }, 210);
      }

      function resetProjectPages() {
        individualProjectPage.hidden = true;
        individualProjectPage.classList.remove("active", "closing");

        projectCategoryPage.hidden = true;
        projectCategoryPage.classList.remove("active", "closing", "overview-exiting", "behind-detail");

        projectsOverview.hidden = false;
        projectsOverview.classList.remove("overview-exiting");
      }

      projectCards.forEach((card) => {
        card.addEventListener("click", () => {
          openCategory(card.dataset.project, card);
        });

        card.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            openCategory(card.dataset.project, card);
          }
        });
      });

      categoryBackButton.addEventListener("click", () => {
        closeCategory(true);
      });

      individualBackButton.addEventListener("click", () => {
        closeIndividualProject(true);
      });

      function showTab(tabName) {
        if (tabName !== "projects") {
          resetProjectPages();
        }

        tabButtons.forEach((button) => {
          button.classList.toggle("active", button.dataset.tab === tabName);
        });

        screens.forEach((screen) => {
          screen.classList.toggle("active", screen.id === tabName);
        });

        history.replaceState(null, "", `#${tabName}`);

        if (tabName === "experience") {
          setTimeout(revealVisibleTimelineItems, 80);
        }
      }

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => {
          showTab(button.dataset.tab);
        });
      });

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              typeExperienceCard(entry.target);
            }
          });
        },
        {
          root: null,
          rootMargin: "0px 0px -30% 0px",
          threshold: 0.4,
        }
      );

      revealItems.forEach((item) => revealObserver.observe(item));

      const startingTab = window.location.hash.replace("#", "");

      if (["education", "projects", "experience"].includes(startingTab)) {
        showTab(startingTab);
      } else {
        showTab("education");
      }
    </script>
  </body>
