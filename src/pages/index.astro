          projectCategoryPage.hidden = false;
          projectCategoryPage.classList.add("active");
          projectCategoryPage.classList.remove("overview-exiting", "behind-detail");
          setAnimating(false);
          return;
        }

        // Snapshot current scroll — all measurements happen here so positions are consistent.
        const currentScrollY = window.scrollY;
        const scrollDelta = savedRowScrollY - currentScrollY;

        // Measure individual title BEFORE showing the category page (layout shift would corrupt it).
        const indStyles = getComputedStyle(individualTitle);
        const indFontSize = parseFloat(indStyles.fontSize);
        const indRange = document.createRange();
        indRange.selectNodeContents(individualTitle);
        const indTextRect = indRange.getBoundingClientRect();

        // Stop rows from replaying their entry animation on re-show — they must be
        // stable and measurable for the reverse title animation to land correctly.
        categoryProjectRows.classList.add("no-replay");

        projectCategoryPage.hidden = false;
        projectCategoryPage.classList.add("active");
        projectCategoryPage.classList.remove("overview-exiting", "behind-detail");

        // Measure row positions at currentScrollY, then adjust by scrollDelta so they
        // match where the row will be once scroll is restored to savedRowScrollY.
        const rect = activeProjectRow ? activeProjectRow.getBoundingClientRect() : null;

        // Force hover transform to neutral before measuring so cursor-over-row
        // doesn't shift the target position by 4px.
        const rowTitleEl = activeProjectRow ? activeProjectRow.querySelector(".project-row-text h3") : null;
        let rowTextRect = null;
        let rowFontSize = 0;
        if (rowTitleEl) {
          activeProjectRow.style.transition = "none";
          activeProjectRow.style.transform = "translateY(0)";
          void activeProjectRow.offsetHeight; // force reflow
          const rowStyles = getComputedStyle(rowTitleEl);
          rowFontSize = parseFloat(rowStyles.fontSize);
          const rowRange = document.createRange();
          rowRange.selectNodeContents(rowTitleEl);
          rowTextRect = rowRange.getBoundingClientRect();
          activeProjectRow.style.transform = "";
          activeProjectRow.style.transition = "";
        }

        // Spawn clone of the individual title before hiding the page.
        let titleClone = null;
        if (rowTextRect) {
          titleClone = document.createElement("div");
          titleClone.textContent = individualTitle.textContent.trim();
          Object.assign(titleClone.style, {
            position: "fixed",
            left: indTextRect.left + "px",
            top: indTextRect.top + "px",
            fontSize: indFontSize + "px",
            fontWeight: indStyles.fontWeight,
            fontFamily: indStyles.fontFamily,
            fontStyle: indStyles.fontStyle,
            fontStretch: indStyles.fontStretch,
            lineHeight: indStyles.lineHeight,
            letterSpacing: indStyles.letterSpacing,
            color: indStyles.color,
            whiteSpace: "nowrap",
            margin: "0",
            padding: "0",
            zIndex: "10001",
            pointerEvents: "none",
            transformOrigin: "0 0",
          });
          titleClone.style.setProperty("-webkit-font-smoothing", getComputedStyle(individualTitle).getPropertyValue("-webkit-font-smoothing") || "antialiased");
          titleClone.style.setProperty("-moz-osx-font-smoothing", "grayscale");
          document.body.appendChild(titleClone);

          // Measure ink overflow at indFontSize — large at this size, so correct
          // at both ends of the animation.
          const cloneTestRange = document.createRange();
          cloneTestRange.selectNodeContents(titleClone);
          const cloneInkOffset = cloneTestRange.getBoundingClientRect().top - titleClone.getBoundingClientRect().top;

          // Shift element down so clone ink aligns with h2 ink at the start.
          titleClone.style.top = (indTextRect.top - cloneInkOffset) + "px";

          const revScale = indFontSize > 0 ? rowFontSize / indFontSize : 1;
          const tx = rowTextRect.left - indTextRect.left;
          // tyBase without hover bias — bias is applied in rAF after scroll takes effect.
          const tyBase = rowTextRect.top - indTextRect.top + cloneInkOffset * (1 - revScale) - scrollDelta;

          individualTitle.style.opacity = "0";

          const hero = document.createElement("div");
          hero.id = "card-expand-hero";
          hero.style.left = "0px";
          hero.style.top = "0px";
          hero.style.width = "100vw";
          hero.style.height = "100vh";
          hero.style.borderRadius = "0px";
          document.body.appendChild(hero);

          // Restore scroll now — hero covers the page so the jump is invisible.
          window.scrollTo({ top: savedRowScrollY, behavior: "auto" });

          individualProjectPage.hidden = true;
          individualProjectPage.classList.remove("active", "closing");

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              // Check hover after scroll has taken effect using elementFromPoint,
              // since :hover state doesn't update until the next pointer event.
              const elemUnder = document.elementFromPoint(mouseX, mouseY);
              const rowHovered = activeProjectRow.contains(elemUnder) || activeProjectRow === elemUnder;
              const ty = tyBase + (rowHovered ? -4 : 0.5);

              if (rect) {
                hero.style.left = rect.left + "px";
                hero.style.top = (rect.top - scrollDelta) + "px";
                hero.style.width = rect.width + "px";
                hero.style.height = rect.height + "px";
                hero.style.borderRadius = "14px";
              }
              titleClone.style.transition = "transform 0.32s cubic-bezier(0.4, 0, 0.2, 1)";
              titleClone.style.transform = `translate(${tx}px, ${ty}px) scale(${revScale})`;
            });
          });

          // Keep the clone visible until the hero is fully faded, then remove both
          // together — the real row title appears seamlessly with no blank or fade gap.
          setTimeout(() => {
            hero.classList.add("hero-fade-out");
          }, 320);

          setTimeout(() => {
            titleClone.remove();
            individualTitle.style.opacity = "";
            hero.remove();
            setAnimating(false);
          }, 680);

          return;
        }

        // Fallback: no row reference, just animate hero.
        const hero = document.createElement("div");
        hero.id = "card-expand-hero";
        hero.style.left = "0px";
        hero.style.top = "0px";
        hero.style.width = "100vw";
        hero.style.height = "100vh";
        hero.style.borderRadius = "0px";
        document.body.appendChild(hero);

        window.scrollTo({ top: savedRowScrollY, behavior: "auto" });

        individualProjectPage.hidden = true;
        individualProjectPage.classList.remove("active", "closing");

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            if (rect) {
              hero.style.left = rect.left + "px";
              hero.style.top = (rect.top - scrollDelta) + "px";
              hero.style.width = rect.width + "px";
              hero.style.height = rect.height + "px";
              hero.style.borderRadius = "14px";
            }
          });
        });

        setTimeout(() => {
          hero.classList.add("hero-fade-out");
          setTimeout(() => {
            hero.remove();
            setAnimating(false);
          }, 560);
        }, 280);
      }

      function resetProjectPages() {
        individualProjectPage.hidden = true;
        individualProjectPage.classList.remove("active", "closing");

        projectCategoryPage.hidden = true;
        projectCategoryPage.classList.remove("active", "closing", "overview-exiting", "behind-detail");

        projectsOverview.hidden = false;
        projectsOverview.classList.remove("overview-exiting");
      }

      projectCards.forEach((card) => {
        card.addEventListener("click", () => {
          openCategory(card.dataset.project, card);
        });

        card.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            openCategory(card.dataset.project, card);
          }
        });
      });

      categoryBackButton.addEventListener("click", () => {
        closeCategory(true);
      });

      individualBackButton.addEventListener("click", () => {
        closeIndividualProject(true);
      });

      let tabTransitioning = false;

      // Replays the staggered slide-in on a screen's cards each time it
      // becomes active. Hides them (.pre-slide), restarts the animation,
      // then removes both classes once finished so the held transform
      // doesn't override hover/launch states.
      function triggerCardSlideIn(screen) {
        if (!screen) return;
        const cards = screen.querySelectorAll(".slide-card");
        cards.forEach((card, index) => {
          card.classList.remove("card-in");
          card.classList.add("pre-slide");
          card.style.setProperty("--card-index", index);
        });
        // Force reflow so the restart takes effect.
        void screen.offsetHeight;
        requestAnimationFrame(() => {
          cards.forEach((card) => {
            const cleanup = () => {
              card.classList.remove("card-in", "pre-slide");
              card.removeEventListener("animationend", cleanup);
            };
            card.addEventListener("animationend", cleanup);
            card.classList.remove("pre-slide");
            card.classList.add("card-in");
          });
        });
      }

      // Remembers how far down each tab was scrolled so returning to a tab
      // restores its position. Experience always opens at the top.
      const tabScrollPositions = {};

      function showTab(tabName) {
        const currentScreen = document.querySelector(".screen.active");
        const nextScreen = document.getElementById(tabName);

        // Nothing to do if we're already on this tab.
        if (currentScreen === nextScreen) return;

        // Save where the outgoing tab was scrolled before we swap.
        if (currentScreen) {
          tabScrollPositions[currentScreen.id] = window.scrollY;
        }

        if (tabName !== "projects") {
          resetProjectPages();
        }

        tabButtons.forEach((button) => {
          button.classList.toggle("active", button.dataset.tab === tabName);
        });

        history.replaceState(null, "", `#${tabName}`);

        const revealNextIfNeeded = () => {
          if (tabName === "experience") {
            setTimeout(revealVisibleTimelineItems, 60);
          }
        };

        const activateNext = () => {
          screens.forEach((screen) => {
            screen.classList.toggle("active", screen === nextScreen);
          });

          // Experience always opens at the top; every other tab restores the
          // scroll position it had when you last left it.
          const targetScroll =
            tabName === "experience"
              ? 0
              : tabScrollPositions[tabName] ?? 0;
          window.scrollTo({ top: targetScroll, behavior: "auto" });

          triggerCardSlideIn(nextScreen);
          revealNextIfNeeded();
          if (tabName === "education") setTimeout(animateCounters, 80);
          tabTransitioning = false;
        };

        // No outgoing screen (first paint) — just bring the new one in.
        if (!currentScreen) {
          activateNext();
          return;
        }

        // Reduced-motion users: skip the choreography.
        const reduceMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;
        if (reduceMotion) {
          activateNext();
          return;
        }

        // Animate the current screen out, then swap to the next one. Guard
        // against overlapping transitions from rapid clicking.
        tabTransitioning = true;
        currentScreen.classList.remove("active");
        currentScreen.classList.add("exiting");

        const finishExit = () => {
          currentScreen.removeEventListener("animationend", finishExit);
          currentScreen.classList.remove("exiting");
          activateNext();
        };

        currentScreen.addEventListener("animationend", finishExit);
        // Fallback in case animationend doesn't fire.
        setTimeout(() => {
          if (currentScreen.classList.contains("exiting")) finishExit();
        }, 360);
      }

      tabButtons.forEach((button) => {
        button.addEventListener("click", () => {
          if (tabTransitioning) return;
          showTab(button.dataset.tab);
        });
      });

      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        {
          root: null,
          rootMargin: "0px 0px -30% 0px",
          threshold: 0.4,
        }
      );

      revealItems.forEach((item) => revealObserver.observe(item));

      const startingTab = window.location.hash.replace("#", "");
      const validStart = ["education", "projects", "experience"].includes(
        startingTab
      )
        ? startingTab
        : "education";

      // On first paint, activate the starting screen directly (no exit
      // animation from the markup default).
      if (validStart !== "education") {
        screens.forEach((screen) =>
          screen.classList.toggle("active", screen.id === validStart)
        );
        tabButtons.forEach((button) =>
          button.classList.toggle("active", button.dataset.tab === validStart)
        );
        history.replaceState(null, "", `#${validStart}`);
        if (validStart === "experience") {
          setTimeout(revealVisibleTimelineItems, 60);
        }
      }

      // Run the staggered card slide-in on whichever screen loaded active.
      triggerCardSlideIn(document.getElementById(validStart));
      if (validStart === "education") setTimeout(animateCounters, 120);

      // ===== Animated hero constellation (cursor-repel) =====
      (function () {
        const c = document.getElementById("heroCanvas");
        if (!c) return;
        const ctx = c.getContext("2d");
        const dpr = Math.min(2, window.devicePixelRatio || 1);
        let w = 0, h = 0, pts = [];
        const mouse = { x: -9999, y: -9999 };
        const REPEL = 140;
        function resize() {
          w = c.offsetWidth; h = c.offsetHeight;
          c.width = w * dpr; c.height = h * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          const n = Math.min(80, Math.round((w * h) / 16000));
          pts = Array.from({ length: n }, () => ({
            x: Math.random() * w, y: Math.random() * h,
            vx: (Math.random() - 0.5) * 0.28, vy: (Math.random() - 0.5) * 0.28
          }));
        }
        resize();
        window.addEventListener("resize", resize);
        c.addEventListener("mousemove", (e) => {
          const r = c.getBoundingClientRect();
          mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
        });
        c.addEventListener("mouseleave", () => { mouse.x = -9999; mouse.y = -9999; });
        (function loop() {
          ctx.clearRect(0, 0, w, h);
          for (const p of pts) {
            p.x += p.vx; p.y += p.vy;
            if (p.x < 0 || p.x > w) p.vx *= -1;
            if (p.y < 0 || p.y > h) p.vy *= -1;
            const dx = p.x - mouse.x, dy = p.y - mouse.y, dm = Math.hypot(dx, dy) || 1;
            const near = dm < REPEL;
            if (near) {
              const f = (1 - dm / REPEL) * 5;
              p.x += (dx / dm) * f; p.y += (dy / dm) * f;
              p.x = Math.max(0, Math.min(w, p.x)); p.y = Math.max(0, Math.min(h, p.y));
            }
            ctx.beginPath();
            ctx.arc(p.x, p.y, near ? 2.8 : 1.6, 0, Math.PI * 2);
            ctx.fillStyle = near ? "rgba(41,182,255,.95)" : "rgba(120,140,160,.5)";
            ctx.fill();
          }
          for (let i = 0; i < pts.length; i++) {
            for (let j = i + 1; j < pts.length; j++) {
              const a = pts[i], b = pts[j];
              const d = Math.hypot(a.x - b.x, a.y - b.y);
              if (d < 120) {
                ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
                ctx.strokeStyle = "rgba(90,110,130," + (0.18 * (1 - d / 120)) + ")";
                ctx.lineWidth = 1; ctx.stroke();
              }
            }
          }
          requestAnimationFrame(loop);
        })();
      })();

      // ===== Education stat counters =====
      function animateCounters() {
        document.querySelectorAll("#education [data-count]").forEach((el) => {
          const target = parseFloat(el.getAttribute("data-count"));
          const dec = parseInt(el.getAttribute("data-dec") || "0", 10);
          const dur = 1200, start = performance.now();
          function step(now) {
            const p = Math.min(1, (now - start) / dur);
            const e = 1 - Math.pow(1 - p, 3);
            el.textContent = (target * e).toFixed(dec);
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
