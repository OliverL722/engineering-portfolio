      let isAnimating = false;
      let mouseX = 0, mouseY = 0;
      document.addEventListener("mousemove", e => { mouseX = e.clientX; mouseY = e.clientY; });

      // Hover is disabled on cards and rows for the entire duration of a page
      // transition. A mid-animation hover lift (translateY(-4px)) moves the real
      // title while the flying clone heads to a precomputed position, leaving two
      // copies of the text offset from each other. The body.hover-lock class kills
      // pointer events on the hover targets until cleanup completes; elementFromPoint
      // then also correctly reports "not hovered", keeping the landing bias in sync.
      function setAnimating(value) {
        isAnimating = value;
        document.body.classList.toggle("hover-lock", value);
      }

      // Scrolling is also blocked while a transition runs, for the same reason as
      // hover: the flying title clone is position:fixed, but its landing position
      // was measured against the document — scrolling mid-animation moves the real
      // title while the clone lands at the stale coordinate. Inputs are blocked
      // rather than using overflow:hidden, which would remove the scrollbar and
      // reflow the page, corrupting the positions the animation already measured.
      // Programmatic scrolls (jumpToProjectsTop, scroll restoration) are unaffected.
      function blockScrollInput(event) {
        if (isAnimating) event.preventDefault();
      }

      window.addEventListener("wheel", blockScrollInput, { passive: false });
      window.addEventListener("touchmove", blockScrollInput, { passive: false });

      const scrollKeys = new Set([
        "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight",
        "PageUp", "PageDown", "Home", "End", " ",
      ]);

      window.addEventListener("keydown", (event) => {
        if (isAnimating && scrollKeys.has(event.key)) {
          event.preventDefault();
        }
      });

